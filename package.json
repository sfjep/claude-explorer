  "license": "MIT",
  "homepage": "https://github.com/sfjep/claude-viewer#readme",
  "bugs": {
    "url": "https://github.com/sfjep/claude-viewer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sfjep/claude-viewer.git"
  },
  "bin": {
    "claude-viewer": "./server.mjs"
  },
  "main": "./server.mjs",
  "files": [
    "server.mjs",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
